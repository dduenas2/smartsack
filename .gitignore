# =============================================================================
# .gitignore — SmartSack
# Archivos y directorios que no deben versionarse en el repositorio Git.
# =============================================================================

# ----- Variables de entorno y secretos -----
.env
.env.local
.env.*.local
*.pem
*.key

# ----- Python / Backend -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Entornos virtuales
venv/
env/
ENV/
.venv/

# Pytest / cobertura
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Modelos ML serializados grandes (mantener solo versionados con DVC/LFS si aplica)
backend/ml/models/*.joblib
backend/ml/models/*.pkl

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----- Node / Frontend -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build de Vite
frontend/dist/
frontend/build/
.vite/

# ----- Editores / IDEs -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Docker -----
docker-compose.override.yml

# ----- Logs -----
*.log
logs/

# ----- Datos sensibles / generados -----
backend/etl/sample_data/*.csv
!backend/etl/sample_data/.gitkeep
# CSV de muestra versionado a propósito (entregable del refactor de confirmations).
!backend/etl/sample_data/confirmations_sample.csv

# ----- Sistema operativo -----
.DS_Store
.AppleDouble
.LSOverride
ehthumbs.db
desktop.ini

# Metadatos de Windows (marca "descargado de internet")
*:Zone.Identifier

# ----- Documentos binarios y artefactos fuera del repo de código -----
# Documentos institucionales del TG (.docx) y temporales de Word: se entregan aparte.
*.docx
*.doc
*.pptx
~$*
# Prompts de desarrollo: artefactos de construcción, no parte del código entregable.
PROMPT_*.txt
# Instrucciones del asistente de IA (Claude Code): artefacto de desarrollo, no entregable.
CLAUDE.md
