# =============================================================================
# .env.example — Plantilla de variables de entorno de SmartSack
# -----------------------------------------------------------------------------
# Copiar este archivo a .env y completar los valores reales:
#   $ cp .env.example .env
# Este archivo SÍ se versiona; .env NO.
#
# Antes de levantar el stack:
#   1. Definir POSTGRES_PASSWORD (cualquier string fuerte).
#   2. Definir DATABASE_URL con la misma contraseña.
#   3. Definir JWT_SECRET_KEY: usa `openssl rand -hex 32` o similar.
#   4. (Opcional) ANTHROPIC_API_KEY para activar el chatbot en modo LLM.
#      Sin ella, el chatbot funciona en modo fallback (heurística por keywords).
# =============================================================================

# ----- Entorno general -----
ENVIRONMENT=development
PROJECT_NAME=SmartSack
TZ=America/Bogota

# ----- PostgreSQL -----
# La contraseña se incluye también en DATABASE_URL — mantén ambas en sincronía.
POSTGRES_USER=smartsack
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=smartsack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://smartsack:CHANGE_ME@postgres:5432/smartsack

# ----- Redis -----
# Caché de estado de máquinas + canal de pub/sub para WebSockets en el futuro.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ----- Backend FastAPI -----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
# Genera con: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_HEX_OF_32_BYTES
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
# Orígenes permitidos por CORS — separar por coma. En producción, usa el dominio real.
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ----- Frontend (Vite) -----
# Vite expone solo variables que empiezan con VITE_ al bundle del navegador.
VITE_API_BASE_URL=/api
VITE_WS_BASE_URL=/ws

# ----- API de Claude (Anthropic) -----
# Si está vacía o es un placeholder, el chatbot opera en modo fallback.
# Obtén una clave en https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- Logging -----
LOG_LEVEL=INFO
